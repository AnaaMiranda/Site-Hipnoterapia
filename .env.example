# Variáveis de ambiente. Copie para `.env.local` e preencha.

# URL pública do site (SEO, sitemap, Open Graph, JSON-LD)
NEXT_PUBLIC_SITE_URL=https://www.julianemachado.com.br

# Endpoint do Google Apps Script que recebe os formulários.
# Sem esta variável, os formulários rodam em modo de demonstração.
NEXT_PUBLIC_SHEETS_URL=

# Google Analytics 4 (opcional) — carregado apenas após consentimento (LGPD)
NEXT_PUBLIC_GA_ID=

# Google Tag Manager (opcional) — carregado apenas após consentimento (LGPD)
NEXT_PUBLIC_GTM_ID=

# Verificação do Google Search Console (opcional)
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=
